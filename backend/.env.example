PORT=8090
GROQ_API_KEY=your-groq-api-key-here

# ================================================================
# Microsoft Entra ID (Azure AD) SSO Configuration
# ================================================================
# To enable SSO, register an app in Azure Portal:
#   1. Go to Azure Portal > Microsoft Entra ID > App registrations
#   2. Create a new registration
#   3. Add Redirect URIs:
#      - Local:  http://localhost:8090/auth/callback
#      - Prod:   https://your-app.up.railway.app/auth/callback
#   4. Copy Client ID, create a Client Secret, and note your Tenant ID
#   5. Fill in the values below
# ================================================================
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_TENANT_ID=your-tenant-id-here

# Optional: Restrict login to a specific email domain (e.g., yourcompany.com)
# If not set, the Tenant ID restriction is still enforced
ALLOWED_DOMAIN=

# Session Secret (generate a random string for production)
SECRET_KEY=change-this-to-a-secure-random-string

# Base URL override for OAuth redirect URIs
# Set in production (e.g. https://your-app.up.railway.app)
# Leave empty for local dev (auto-detects localhost)
BASE_URL=
